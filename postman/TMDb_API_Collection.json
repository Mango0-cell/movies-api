{
  "info": {
    "name": "TMDb REST API",
    "description": "Collection for the TMDb REST API proxy",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Movies",
      "item": [
        {
          "name": "List Movies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/movies?page=1&language=en-US",
              "host": ["{{base_url}}"],
              "path": ["api", "movies"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "language", "value": "en-US" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Has pagination', () => { const j = pm.response.json(); pm.expect(j.pagination).to.have.property('page'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Movies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/movies?query=inception&page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "movies"],
              "query": [
                { "key": "query", "value": "inception" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Movie Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/movies/550",
              "host": ["{{base_url}}"],
              "path": ["api", "movies", "550"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has success true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ]
        }
      ]
    },
